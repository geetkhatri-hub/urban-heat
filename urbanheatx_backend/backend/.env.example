# Copy this file to .env and adjust as needed

# City the whole dashboard is centered on (default: Bengaluru, matches the seed data)
CITY_NAME=Bengaluru
CITY_LAT=12.9716
CITY_LON=77.5946

# Reference average temperature (°C) the original seed dataset (wards.json / heatData.json)
# was authored around. Used to compute each ward's fixed "urban heat island offset"
# relative to the live city temperature. Don't change unless you re-author the seed data.
REFERENCE_CITY_TEMP=38.4

# SQLite by default. For Postgres use e.g.:
# DATABASE_URL=postgresql://user:password@localhost:5432/urbanheat
DATABASE_URL=sqlite:///./urbanheat.db

# Allow your Vite dev server to call the API (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# How long (minutes) to cache the Open-Meteo response before refetching
WEATHER_CACHE_MINUTES=30
